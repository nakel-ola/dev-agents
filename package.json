{
  "name": "devagents",
  "displayName": "DevAgents",
  "description": "Create, manage, and run reusable AI agents inside VS Code using Claude CLI, Codex CLI, and Gemini CLI.",
  "version": "1.0.0",
  "publisher": "devagents",
  "icon": "media/devagents.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nakel-ola/dev-agents.git"
  },
  "bugs": {
    "url": "https://github.com/nakel-ola/dev-agents/issues"
  },
  "homepage": "https://github.com/nakel-ola/dev-agents#readme",
  "galleryBanner": {
    "color": "#0f0f11",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "ai",
    "agents",
    "claude",
    "codex",
    "gemini",
    "workflow"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "devagents.runAgent",
        "title": "DevAgents: Run Agent",
        "icon": "$(play)"
      },
      {
        "command": "devagents.runAgentOnSelection",
        "title": "DevAgents: Run Agent On Selection",
        "icon": "$(run-all)"
      },
      {
        "command": "devagents.createAgent",
        "title": "DevAgents: Create Agent",
        "icon": "$(add)"
      },
      {
        "command": "devagents.openAgentPanel",
        "title": "DevAgents: Open Agent Panel",
        "icon": "$(layout-sidebar-left)"
      },
      {
        "command": "devagents.refreshAgents",
        "title": "DevAgents: Refresh Agents",
        "icon": "$(refresh)"
      },
      {
        "command": "devagents.editAgent",
        "title": "DevAgents: Edit Agent",
        "icon": "$(edit)"
      },
      {
        "command": "devagents.deleteAgent",
        "title": "DevAgents: Delete Agent",
        "icon": "$(trash)"
      },
      {
        "command": "devagents.runWorkflow",
        "title": "DevAgents: Run Workflow",
        "icon": "$(symbol-event)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devagents",
          "title": "DevAgents",
          "icon": "media/devagents.svg"
        }
      ]
    },
    "views": {
      "devagents": [
        {
          "id": "devagents.sidebar",
          "name": "DevAgents",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/context": [
        {
          "command": "devagents.runAgentOnSelection",
          "when": "editorHasSelection",
          "group": "devagents@1"
        },
        {
          "command": "devagents.runAgent",
          "group": "devagents@2"
        }
      ],
      "commandPalette": [
        {
          "command": "devagents.runAgent"
        },
        {
          "command": "devagents.runAgentOnSelection",
          "when": "editorHasSelection"
        },
        {
          "command": "devagents.createAgent"
        },
        {
          "command": "devagents.openAgentPanel"
        },
        {
          "command": "devagents.refreshAgents"
        },
        {
          "command": "devagents.editAgent"
        },
        {
          "command": "devagents.deleteAgent"
        },
        {
          "command": "devagents.runWorkflow"
        }
      ]
    },
    "configuration": {
      "title": "DevAgents",
      "properties": {
        "devagents.agentsFolder": {
          "type": "string",
          "default": ".agents",
          "description": "Folder containing DevAgents agent and workflow YAML files."
        },
        "devagents.autoOpenOutput": {
          "type": "boolean",
          "default": true,
          "description": "Automatically show the output channel when an agent runs."
        },
        "devagents.outputVerbose": {
          "type": "boolean",
          "default": false,
          "description": "Log the full rendered prompt to the output channel."
        },
        "devagents.providerTimeoutMs": {
          "type": "number",
          "default": 120000,
          "minimum": 1000,
          "description": "Timeout in milliseconds for provider CLI execution."
        },
        "devagents.providers.claude.command": {
          "type": "string",
          "default": "claude",
          "description": "Claude CLI executable."
        },
        "devagents.providers.claude.args": {
          "type": "array",
          "default": [
            "-p",
            "{prompt}"
          ],
          "items": {
            "type": "string"
          },
          "description": "Claude CLI arguments. Use {prompt} and {model} as placeholders."
        },
        "devagents.providers.codex.command": {
          "type": "string",
          "default": "codex",
          "description": "OpenAI Codex CLI executable."
        },
        "devagents.providers.codex.args": {
          "type": "array",
          "default": [
            "exec",
            "{prompt}"
          ],
          "items": {
            "type": "string"
          },
          "description": "Codex CLI arguments. Use {prompt} and {model} as placeholders."
        },
        "devagents.providers.gemini.command": {
          "type": "string",
          "default": "gemini",
          "description": "Gemini CLI executable."
        },
        "devagents.providers.gemini.args": {
          "type": "array",
          "default": [
            "-p",
            "{prompt}"
          ],
          "items": {
            "type": "string"
          },
          "description": "Gemini CLI arguments. Use {prompt} and {model} as placeholders."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p tsconfig.json && node esbuild.mjs && npx @tailwindcss/cli -i src/webviews/styles/globals.css -o media/webview.css --minify",
    "compile:ext": "tsc -p tsconfig.json",
    "compile:webview": "node esbuild.mjs && npx @tailwindcss/cli -i src/webviews/styles/globals.css -o media/webview.css --minify",
    "watch:ext": "tsc -w -p tsconfig.json",
    "watch:webview": "node esbuild.mjs --watch",
    "vscode:prepublish": "tsc -p tsconfig.json && node esbuild.mjs --minify && npx @tailwindcss/cli -i src/webviews/styles/globals.css -o media/webview.css --minify",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/vsce": "^2.24.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "esbuild": "^0.27.4",
    "lucide-react": "^0.577.0",
    "ovsx": "^0.10.9",
    "preact": "^10.29.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "yaml": "^2.7.0"
  }
}
