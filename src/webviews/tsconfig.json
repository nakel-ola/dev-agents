{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "react": ["../../node_modules/preact/compat/"],
      "react-dom": ["../../node_modules/preact/compat/"],
      "react/jsx-runtime": ["../../node_modules/preact/jsx-runtime"]
    }
  },
  "include": ["./**/*.ts", "./**/*.tsx"]
}
